<resources>
    <!-- Base application theme. -->
    <style name="Theme.Template" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue300</item>
        <item name="colorPrimaryDark">@color/blue400</item>
        <item name="colorAccent">@color/yellow400</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/black30</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/appBackground</item>
        <item name="android:popupBackground">@color/appBackground</item>
        <item name="android:textColor">@color/colorPrimary</item>

    </style>
</resources>